# Example configuration file.
# Copy this file to .env and replace placeholder values in your private lab.
# Do not commit .env.

RECEIVER_SERVER_IP=<receiver_server_ip>
CLIENT_VM_IP=<client_vm_ip>
GATEWAY_IP=<gateway_ip>
VISIBILITY_BRIDGE_IP=<visibility_platform_bridge_ip>

PFSENSE_IP=<pfsense_ip>
# pfSense was used as the router/firewall/NAT example in the original lab.
# Other open-source firewall or routing platforms may be used.

RECEIVER_HOSTNAME=<your_receiver_hostname>
CLIENT_HOSTNAME=<your_client_hostname>

RECEIVER_USERNAME=<receiver_username>
CLIENT_USERNAME=<client_username>

WEB_UI_PORT=8080
